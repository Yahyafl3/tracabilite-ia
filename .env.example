# ===========================================
# Variables d'Environnement - Traçabilité IA
# ===========================================
# Copier ce fichier en .env et adapter les valeurs

# ===========================================
# BASE DE DONNÉES PRINCIPALE (PostgreSQL)
# ===========================================
POSTGRES_DB=tracabilite_ia
POSTGRES_USER=tracabilite
POSTGRES_PASSWORD=tracabilite123
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tracabilite_ia
SPRING_DATASOURCE_USERNAME=tracabilite
SPRING_DATASOURCE_PASSWORD=tracabilite123
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=tracabilite-ia-super-secret-key-please-change-in-production-0123456789
JWT_EXPIRATION_MS=86400000

# ===========================================
# OPENROUTER (3 agents generatifs)
# ===========================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_1=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_2=google/gemma-4-26b-a4b-it:free
OPENROUTER_MODEL_3=openai/gpt-oss-20b:free
OPENROUTER_AGENT_1_FALLBACK=
OPENROUTER_AGENT_2_FALLBACK=
OPENROUTER_AGENT_3_FALLBACK=
OPENROUTER_USE_FREE_ROUTER=false
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Tracabilite-IA
OPENROUTER_AGENT_DELAY_MS=3000

# ===========================================
# SERVICE ML (FastAPI + Scikit-learn)
# ===========================================
ML_SERVICE_URL=http://ml-service:5000
ML_MODEL_PATH=/app/models
ML_MODEL_VERSION=1.0.0

# ===========================================
# FRONTEND
# ===========================================
FRONTEND_URL=http://localhost:80
BACKEND_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:4200

# ===========================================
# ENVIRONNEMENT
# ===========================================
ENVIRONMENT=development
LOG_LEVEL=DEBUG
